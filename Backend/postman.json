{
  "info": {
    "name": "E-commerce Agency - User API",
    "_postman_id": "f0f8b4d2-2f1f-4b8a-9c50-7ef0a91f4de1",
    "description": "Dummy test data and requests for user.controller.ts endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userEmail",
      "value": "john.user@testmail.com"
    },
    {
      "key": "userPassword",
      "value": "User@12345"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin@testmail.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin@12345"
    },
    {
      "key": "adminToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "User Auth",
      "item": [
        {
          "name": "Signup User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John User\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"9876543210\",\n  \"password\": \"{{userPassword}}\",\n  \"address\": {\n    \"line1\": \"221B Baker Street\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"country\": \"India\",\n    \"pincode\": \"400001\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "signup"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('userToken', data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin (Pre-seeded Admin User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 when admin exists', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data && data.token) {",
                  "    pm.collectionVariables.set('adminToken', data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Protected Routes",
      "item": [
        {
          "name": "Get Profile (User Token)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "profile"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Profile call is successful', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Admin Route With User Token (Expected 403)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "admin"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User cannot access admin route', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Admin Route With Admin Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "admin"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin access result', function () {",
                  "  pm.expect([200, 401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile Without Token (Expected 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "profile"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unauthorized without token', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
